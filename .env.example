TOKEN="MyBotToken"
LOG_URL="https://logviewername.herokuapp.com/"
GUILD_ID="1234567890"
OWNERS="Owner1ID,Owner2ID,Owner3ID"
CONNECTION_URI="mongodb+srv://mongodburi"
DISABLE_AUTOUPDATES="true"

S3_ENDPOINT="http://ip:port"
S3_ACCESS_KEY="./garage -c /etc/garage.toml key create key_name"
S3_SECRET_KEY="./garage -c /etc/garage.toml bucket allow bucket_name --read --write --key key_name"
S3_PUBLIC_URL="http://ip:port/bucket_name"

# Dashboard websocket bridge (web-dashboard). Leave DASHBOARD_WS_SECRET empty to disable.
DASHBOARD_WS_SECRET=""
DASHBOARD_WS_HOST="0.0.0.0"
DASHBOARD_WS_PORT="8765"
DASHBOARD_MAX_ATTACHMENT_MB="8"